generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  USER
}

enum WorkspaceRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  AWAITING_CONFIRMATION
  DONE
  FAILED
}

enum FsOperation {
  DELETE
  MOVE
  COPY
  MKDIR
  UPLOAD
}

enum FsActionStatus {
  DONE
  UNDONE
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  displayName  String
  passwordHash String
  role         UserRole  @default(USER)
  approved     Boolean   @default(false)
  deletedAt    DateTime? // Soft delete: non-null means the account has been deactivated/rejected
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  uploadedFiles            UploadedFile[]
  chatSessions             ChatSession[]
  pendingToolConfirmations PendingToolConfirmation[]
  workspaceMemberships     WorkspaceMember[]
  agentRuns                AgentRun[]
  workspaceFiles           WorkspaceFile[]
  personalFolder           PersonalFolder?
  fsActions                FileSystemAction[]
}

// ---------------------------------------------------------------------------
// Personal Folders — user-private storage on drive 0
// ---------------------------------------------------------------------------

model PersonalFolder {
  id        String   @id @default(cuid())
  userId    String   @unique
  path      String   @unique // relative path, e.g. "0/alice"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Audit Log — immutable record of security-relevant actions
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. USER_APPROVED, USER_REJECTED, FILE_DELETED
  actorId   String?  // Who performed the action (null = system/anonymous)
  targetId  String?  // What was acted upon (user ID, workspace ID, etc.)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetId])
}

// ---------------------------------------------------------------------------
// Workspace — the central unit of collaboration
// ---------------------------------------------------------------------------

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members    WorkspaceMember[]
  chats      ChatSession[]
  agentRuns  AgentRun[]
  files      WorkspaceFile[]
  fsActions  FileSystemAction[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// ---------------------------------------------------------------------------
// Files — workspace-scoped file tracking
// ---------------------------------------------------------------------------

model UploadedFile {
  id           String   @id @default(cuid())
  relativePath String   @unique
  uploadedById String
  uploadedAt   DateTime @default(now())

  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model WorkspaceFile {
  id           String   @id @default(cuid())
  workspaceId  String
  path         String
  name         String
  mimeType     String?
  size         Int?
  uploadedById String
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, path])
  @@index([workspaceId])
}

// ---------------------------------------------------------------------------
// Chat — workspace-scoped conversations
// ---------------------------------------------------------------------------

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String?
  title       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages                 ChatMessage[]
  user                     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace                Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pendingToolConfirmations PendingToolConfirmation[]
  agentRuns                AgentRun[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([workspaceId, updatedAt(sort: Desc)])
}

model PendingToolConfirmation {
  id            String   @id @default(cuid())
  userId        String
  chatSessionId String
  payload       Json
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ChatMessage {
  id            String          @id @default(cuid())
  chatSessionId String
  role          ChatMessageRole
  content       String
  sources       Json?
  toolCalls     Json?
  model         String?
  iterations    Int?
  createdAt     DateTime        @default(now())
  chatSession   ChatSession     @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
}

// ---------------------------------------------------------------------------
// Agent Runs — persistent, workspace-scoped execution tracking
// ---------------------------------------------------------------------------

model AgentRun {
  id          String         @id @default(cuid())
  workspaceId String?
  chatId      String
  userId      String
  status      AgentRunStatus @default(QUEUED)
  kind        String         @default("ask")
  error       String?
  metadata    Json?
  steps       Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chat      ChatSession @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, chatId])
  @@index([chatId, status])
  @@index([userId, status])
}

// ---------------------------------------------------------------------------
// FileSystemAction — undo/redo history for filesystem mutations
// ---------------------------------------------------------------------------

model FileSystemAction {
  id          String         @id @default(cuid())
  workspaceId String?
  userId      String
  operation   FsOperation
  payload     Json           // operation-specific data needed for undo/redo
  status      FsActionStatus @default(DONE)
  description String         // human-readable, e.g. "Deleted 0/photos/img.jpg"
  createdAt   DateTime       @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([userId, workspaceId, status, createdAt(sort: Desc)])
}
