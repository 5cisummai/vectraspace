MEDIA_ROOTS=/path/to/your/media
MAX_UPLOAD_SIZE=10737418240
BODY_SIZE_LIMIT=10G
PORT=3000

# PostgreSQL (Docker Compose)
DATABASE_URL=postgresql://mediaserver:mediaserver@localhost:5432/mediaserver

# Semantic search (Step 8)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
# Optional alternative if your deployment uses bearer auth instead of api-key headers
QDRANT_BEARER_TOKEN=
QDRANT_COLLECTION=media_semantic
# Optional dedicated collection for content chunk ingestion routes
QDRANT_INGEST_COLLECTION=media_ingest
# Min cosine similarity for ingest chunk retrieval in /api/brain/ask (0–1)
BRAIN_INGEST_MIN_SCORE=0.2

# Recommended multimodal setup for Docker CPU environments
EMBEDDING_PROVIDER=multimodal
MULTIMODAL_EMBEDDING_URL=http://127.0.0.1:8000/embed
MULTIMODAL_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
MULTIMODAL_EMBEDDING_API_KEY=

# Optional fallback providers
# Embedding provider: ollama | openai
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-model-name

# LLM (Chat completions) - Ollama or OpenAI-compatible
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=
LLM_MODEL=llama3.2
LLM_FAST_MODEL=llama3.2
LLM_TIMEOUT=120000
# Lower = more grounded RAG answers (0–2)
LLM_TEMPERATURE=0.25
# Optional cap for nucleus sampling (0–1)
# LLM_TOP_P=0.9

JWT_SECRET=your_jwt_secret_key