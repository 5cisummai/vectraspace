# =============================================================================
# Media library & workspaces
# =============================================================================
# Comma-separated absolute paths to media roots.
MEDIA_ROOTS=
# When false, workspace UI/API are hidden; core features still use a default workspace.
ENABLE_WORKSPACES=true

# =============================================================================
# Upload limits
# =============================================================================
MAX_UPLOAD_SIZE=10737418240
BODY_SIZE_LIMIT=10G

# =============================================================================
# Thumbnail cache (file browser grid previews)
# =============================================================================
# In-process LRU size in bytes (0 = disable memory cache).
THUMB_MEMORY_CACHE_MAX_BYTES=134217728
# Per media-root disk cache cap in bytes (0 = disable disk cache). Files live under
# <each MEDIA_ROOT>/<THUMB_CACHE_DIRNAME>/.
THUMB_DISK_CACHE_MAX_BYTES=536870912
# Hidden directory name created inside each media root for cached WebP tiles.
THUMB_CACHE_DIRNAME=.vectraspace-thumbs

# Days before `.trash/<actionId>` folders are purged from disk (and Qdrant paths cleaned).
TRASH_RETENTION_DAYS=30

# =============================================================================
# HTTP server
# =============================================================================
PORT=3000
# If behind a reverse proxy on another origin, set for CSRF:
# PUBLIC_ORIGIN=https://example.com

# =============================================================================
# Vector store & embeddings (semantic search)
# =============================================================================
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=qdrant_api_key
QDRANT_COLLECTION=media_semantic
EMBEDDING_PROVIDER=multimodal
# Jina llama-server: POST /embeddings (token-level vectors; app mean-pools). Not /v1/embeddings.
MULTIMODAL_EMBEDDING_URL=http://127.0.0.1:8080/embeddings
# Model id passed in JSON "model" for OpenAI-compatible clients.
MULTIMODAL_EMBEDDING_MODEL=jina-embeddings-v4
MULTIMODAL_EMBEDDING_API_KEY=""
# Optional: vision embedding prompt (Jina llama-server).
# MULTIMODAL_IMAGE_PROMPT=Describe the image.
# Dense vectors default 2048-d; Qdrant uses the length of the first embedding.
SEMANTIC_IMAGE_EMBEDDING=true

# =============================================================================
# Auth
# =============================================================================
JWT_SECRET=

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://mediaserver:mediaserver@localhost:5432/mediaserver
DB_PASSWORD=mediaserver

# =============================================================================
# LLM (chat / agents)
# =============================================================================
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen3.5-4b
LLM_FAST_MODEL=liquid/lfm2.5-1.2b
LLM_TIMEOUT=120000

# =============================================================================
# Jina / llama-server setup (optional — repo scripts only, not read by the app)
# =============================================================================
# Model card: https://huggingface.co/jinaai/jina-embeddings-v4
# GGUF: https://huggingface.co/jinaai/jina-embeddings-v4-text-retrieval-GGUF
# JINA_HF_REPO=jinaai/jina-embeddings-v4-text-retrieval-GGUF
# EMBEDDING_MODEL_DIR=/path/to/models
# EMBEDDING_GGUF_FILENAME=jina-embeddings-v4-text-retrieval-Q4_K_M.gguf
# EMBEDDING_MMPROJ_FILENAME=mmproj-jina-embeddings-v4-retrieval-BF16.gguf
