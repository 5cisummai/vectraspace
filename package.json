{
	"name": "vectraspace",
	"version": "0.1.2",
	"type": "module",
	"description": "Vectraspace media server for local media search and management",
	"license": "MIT",
	"files": [
		"bin",
		"app",
		"docker-compose.yml",
		"embedding-host",
		"scripts",
		"README.md",
		"LICENSE"
	],
	"bin": {
		"vectraspace": "./bin/vectraspace.js"
	},
	"scripts": {
		"onboard": "node ./bin/vectraspace.js onboard",
		"setup": "node ./bin/vectraspace.js setup",
		"init": "node ./bin/vectraspace.js init",
		"start": "node ./bin/vectraspace.js start",
		"up": "node ./bin/vectraspace.js up",
		"stop": "node ./bin/vectraspace.js stop",
		"down": "node ./bin/vectraspace.js down",
		"logs": "node ./bin/vectraspace.js logs",
		"ps": "node ./bin/vectraspace.js ps",
		"doctor": "node ./bin/vectraspace.js doctor",
		"index": "node ./bin/vectraspace.js index",
		"search": "node ./bin/vectraspace.js search",
		"postinstall": "node ./bin/postinstall.js"
	}
}