# Monorepo-aware package ignore rules based on .gitignore

# app workspace
app/.svelte-kit
app/build
app/node_modules
app/.pnpm
app/.vite
app/.cache
app/package
app/npm-debug.log*
app/yarn-debug.log*
app/yarn-error.log*
app/pnpm-debug.log*
app/.DS_Store
app/.vscode/

# embedding-host workspace
embedding-host/.venv
embedding-host/__pycache__
embedding-host/*.pyc
embedding-host/*.pyo
embedding-host/env/
embedding-host/.DS_Store
embedding-host/.vscode/

# Root workspace
.svelte-kit
build
package
node_modules
.env
.env.*
!.env.example
/.output
.vercel
.netlify
.cloudflare
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vectraspace.compose.override.yml
__pycache__/
*.pyc
*.pyo
*.pyd
env/
.venv/
**/.venv
**/.venv/**
**/__pycache__
**/__pycache__/**
**/*.pyc
**/*.pyo
**/*.pyd
**/.DS_Store
**/.vscode
